# Copy this file to .env and fill in values before running
APEX_DATABASE_URL=sqlite+aiosqlite:///./apex.db
APEX_ADMIN_PASSWORD=             # required — set a strong password; app will not start without this
APEX_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# APEX_SECRET_KEY — reserved for future session signing; not currently used by the application
